{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --inspect=0.0.0.0:9229 src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prod": "ts-node -r tsconfig-paths/register -T src/index.ts",
    "build": "tsc --noEmit",
    "lint": "eslint ./src --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint ./src --report-unused-disable-directives --fix",
    "format": "prettier --log-level warn --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "license": "MIT",
  "dependencies": {
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.6",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "express-winston": "^4.2.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "http2-express-bridge": "^1.0.7",
    "luxon": "^3.7.2",
    "mongoose": "^9.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth2-refresh": "^2.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4",
    "yarn": "^1.22.22"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=8.19.0"
  },
  "nodemonConfig": {
    "execMap": {
      "ts": "node --require ts-node/register/transpile-only"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-oauth2-refresh": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "json-schema-library": "^11.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "sonarqube-scanner": "^4.3.5",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4",
    "yarn-upgrade-all": "^0.7.5"
  },
  "packageManager": "yarn@4.12.0"
}
