# Backend server configuration
SERVER_PORT=3001
SERVER_HOSTNAME=backend
ENABLE_HTTPS=true

# SSL certificates (paths inside container)
SSL_PRIVATE_KEY=/etc/express/express.key
SSL_CERTIFICATE=/etc/express/express.pem

# Database configuration
# FERRETDB_HOSTNAME is set in docker-compose.yml
# FERRETDB_USERNAME and FERRETDB_PASSWORD are set from .env in docker-compose.yml
FERRETDB_PORT=27017
FERRETDB_DATABASE=magic-mirror
FERRETDB_SSL=true
FERRETDB_SSL_CA_FILE=/etc/ferretdb/rootCA.pem

# Frontend URL for CORS
FRONTEND_URL=https://yourdomain.com

# Geocoding API key (optional - get from https://geocode.maps.co)
GEOCODE_API_KEY=

# Timezone
TZ=UTC
