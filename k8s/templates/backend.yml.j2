apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: magic-mirror
  labels:
    app: backend
  annotations:
    keel.sh/policy: force
    keel.sh/trigger: poll
    keel.sh/pollSchedule: "@every 5m"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      imagePullSecrets:
        - name: ghcr-pull-secret
      containers:
        - name: backend
          image: {{ registry_url }}/magic-mirror-backend:{{ backend_image_tag | default('latest') }}
          imagePullPolicy: Always
          ports:
            - containerPort: 3001
          envFrom:
            - configMapRef:
                name: backend-config
            - secretRef:
                name: backend-secrets
          volumeMounts:
            - name: ferretdb-ca
              mountPath: /etc/ferretdb
              readOnly: true
          livenessProbe:
            httpGet:
              path: /api/health
              port: 3001
            initialDelaySeconds: 15
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /api/health
              port: 3001
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "500m"
      volumes:
        - name: ferretdb-ca
          secret:
            secretName: ferretdb-tls
            items:
              - key: ferretdb.pem
                path: rootCA.pem
---
apiVersion: v1
kind: Service
metadata:
  name: backend
  namespace: magic-mirror
spec:
  selector:
    app: backend
  ports:
    - port: 3001
      targetPort: 3001
