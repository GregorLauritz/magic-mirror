apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: magic-mirror
  labels:
    app: backend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      containers:
        - name: backend
          image: {{ registry_url }}/magic-mirror-backend:latest
          imagePullPolicy: Always
          ports:
            - containerPort: 3001
          envFrom:
            - configMapRef:
                name: backend-config
            - secretRef:
                name: backend-secrets
          volumeMounts:
            - name: tls-certs
              mountPath: /etc/express
              readOnly: true
            - name: root-ca
              mountPath: /usr/local/share/ca-certificates/rootCA.pem
              subPath: rootCA.pem
              readOnly: true
          livenessProbe:
            httpGet:
              path: /api/health
              port: 3001
              scheme: HTTPS
            initialDelaySeconds: 15
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /api/health
              port: 3001
              scheme: HTTPS
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "500m"
      volumes:
        - name: tls-certs
          secret:
            secretName: backend-tls
            items:
              - key: express.pem
                path: express.pem
              - key: express.key
                path: express.key
        - name: root-ca
          secret:
            secretName: backend-tls
            items:
              - key: rootCA.pem
                path: rootCA.pem
---
apiVersion: v1
kind: Service
metadata:
  name: backend
  namespace: magic-mirror
spec:
  selector:
    app: backend
  ports:
    - port: 3001
      targetPort: 3001
