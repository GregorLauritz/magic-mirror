apiVersion: apps/v1
kind: Deployment
metadata:
  name: oauth2-proxy
  namespace: magic-mirror
  labels:
    app: oauth2-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: oauth2-proxy
  template:
    metadata:
      labels:
        app: oauth2-proxy
    spec:
      containers:
        - name: oauth2-proxy
          image: {{ registry_url }}/magic-mirror-oauth2-proxy:{{ oauth2_proxy_image_tag | default('latest') }}
          imagePullPolicy: IfNotPresent
          args:
            - --config=/opt/conf/oauth2-proxy.cfg
            - --https-address=:443
          ports:
            - containerPort: 443
          envFrom:
            - secretRef:
                name: oauth2-proxy-secrets
          volumeMounts:
            - name: oauth2-proxy-config
              mountPath: /opt/conf
              readOnly: true
            - name: tls-certs
              mountPath: /opt/ssl
              readOnly: true
          livenessProbe:
            httpGet:
              path: /ping
              port: 443
              scheme: HTTPS
            initialDelaySeconds: 10
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /ping
              port: 443
              scheme: HTTPS
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "128Mi"
              cpu: "250m"
      volumes:
        - name: oauth2-proxy-config
          configMap:
            name: oauth2-proxy-config
{% if letsencrypt_enabled | default(false) %}
        - name: tls-certs
          secret:
            secretName: magic-mirror-letsencrypt-tls
            items:
              - key: tls.crt
                path: tls.crt
              - key: tls.key
                path: tls.key
{% else %}
        - name: tls-certs
          secret:
            secretName: oauth2-proxy-tls
            items:
              - key: {{ server_fqdn }}.pem
                path: {{ server_fqdn }}.pem
              - key: {{ server_fqdn }}.key
                path: {{ server_fqdn }}.key
{% endif %}
---
apiVersion: v1
kind: Service
metadata:
  name: oauth2-proxy
  namespace: magic-mirror
spec:
  type: NodePort
  selector:
    app: oauth2-proxy
  ports:
    - port: 443
      targetPort: 443
      nodePort: 30443
